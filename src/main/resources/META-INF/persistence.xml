<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="obsPU" transaction-type="JTA">
        <jta-data-source>jdbc/obs</jta-data-source>
        <class>com.example.entity.Users</class>
        <class>com.example.entity.Course</class>
        <class>com.example.entity.Exam</class>
        <class>com.example.entity.CalendarEvent</class>
        <class>com.example.entity.Announcement</class>
        <class>com.example.entity.FreezeRequest</class>
        <class>com.example.entity.AdvisorAssignment</class>
        <class>com.example.entity.Enrollment</class>
        <properties>
            <property name="eclipselink.ddl-generation" value="create-or-extend-tables"/>
        </properties>
    </persistence-unit>
</persistence>